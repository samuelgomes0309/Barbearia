# ===========================================
# 🔧 CONFIGURAÇÕES DO SERVIDOR
# ===========================================

# Porta em que o servidor Express irá rodar
# Padrão: 3333
PORT=3333

# ===========================================
# 🗄️ BANCO DE DADOS
# ===========================================

# URL de conexão com o PostgreSQL
# Formato: postgresql://USUARIO:SENHA@HOST:PORTA/NOME_DB?schema=public
# ATENÇÃO: Caracteres especiais na senha devem ser codificados em URL encoding
# Exemplo: # vira %23, @ vira %40, etc.
DATABASE_URL="YOUR_POSTGRESQL_CONNECTION_STRING_HERE"

# ===========================================
# 🔐 AUTENTICAÇÃO JWT
# ===========================================

# Chave secreta para assinar e validar tokens JWT
# IMPORTANTE: Gere uma chave aleatória e segura para produção
# Sugestão: use 'openssl rand -hex 32' para gerar uma nova
JWT_SECRET_KEY=YOUR_JWT_SECRET_KEY_HERE

# ===========================================
# 💳 STRIPE - PAGAMENTOS E ASSINATURAS
# ===========================================

# Chave pública do Stripe (usada no frontend)
# Obtida em: https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLIC_KEY=YOUR_STRIPE_PUBLIC_KEY_HERE

# Chave secreta do Stripe (usada no backend)
# ATENÇÃO: NUNCA exponha esta chave publicamente!
STRIPE_API_KEY=STRIPE_SECRET_KEY_HERE

# ID do preço do plano de assinatura premium no Stripe
# Criado em: https://dashboard.stripe.com/products
STRIPE_PRICE=YOUR_STRIPE_PRICE_ID_HERE

# URL de redirecionamento após pagamento bem-sucedido
# Deve apontar para a página de sucesso no seu frontend
STRIPE_SUCCESS_URL=http://localhost:3000/subscription

# URL de redirecionamento se o usuário cancelar o pagamento
# Deve apontar para a página de cancelamento/tentativa no seu frontend
STRIPE_CANCEL_URL=http://localhost:3000/subscription

# Chave secreta do webhook do Stripe
# Obtida ao configurar o webhook em: https://dashboard.stripe.com/webhooks
# IMPORTANTE: Necessária para validar que os eventos vêm realmente do Stripe
STRIPE_WEBHOOK_SECRET=YOUR_STRIPE_WEBHOOK_SECRET_HERE
