# ============================================
# 🔧 CONFIGURAÇÕES DA API BACKEND
# ============================================

# URL base da API backend do BarberPro
# Esta URL é usada para todas as requisições HTTP (login, agendamentos, cortes, etc.)
# 
# Desenvolvimento Local: http://localhost:3333
# Produção: https://api.seubarberpro.com (substitua pela URL real)
#
# ⚠️ IMPORTANTE: Esta variável começa com NEXT_PUBLIC_*, portanto é EXPOSTA no navegador
# Não coloque informações sensíveis aqui!
NEXT_PUBLIC_API_URL=http://localhost:3333

# ============================================
# 💳 STRIPE - GATEWAY DE PAGAMENTO
# ============================================

# Chave pública do Stripe para processar pagamentos e assinaturas premium
# 
# Como obter:
# 1. Acesse https://dashboard.stripe.com/
# 2. Faça login na sua conta
# 3. Vá em "Developers" > "API keys"
# 4. Copie a "Publishable key" (chave pública)
#
# Formato da chave:
# - Teste: pk_test_XXXXXXXXXXXXXX
# - Produção: pk_live_XXXXXXXXXXXXXX
#
# ⚠️ ATENÇÃO: Use SEMPRE a chave de TESTE em desenvolvimento!
# A chave de produção deve ser usada APENAS em ambiente de produção.
#
# Esta chave é PÚBLICA e segura para ser exposta no cliente (frontend)
NEXT_PUBLIC_STRIPE_PUBLIC_KEY=pk_test_sua_chave_publica_aqui

# ============================================
# 📝 INSTRUÇÕES DE USO
# ============================================
#
# 1. Copie este arquivo e renomeie para: .env.local
#    Comando: cp .env.example .env.local
#
# 2. Substitua os valores pelas suas configurações reais
#
# 3. NUNCA faça commit do arquivo .env.local (já está no .gitignore)
#
# 4. Em produção (Vercel, Netlify, etc), configure essas variáveis 
#    no painel de configuração da plataforma de hospedagem
#
# ============================================
# ℹ️ SOBRE VARIÁVEIS NEXT_PUBLIC_*
# ============================================
#
# No Next.js, variáveis que começam com NEXT_PUBLIC_ são:
# - Expostas no navegador (lado do cliente)
# - Acessíveis via process.env.NEXT_PUBLIC_NOME
# - Embutidas no bundle JavaScript em build time
#
# Variáveis SEM o prefixo NEXT_PUBLIC_:
# - Ficam apenas no servidor
# - NÃO são acessíveis no navegador
# - Mais seguras para chaves secretas
#
# ⚠️ NUNCA use NEXT_PUBLIC_ para dados sensíveis como:
#    - Senha de banco de dados
#    - Chaves secretas de API
#    - Tokens privados
#    - Credenciais de autenticação
#
# ============================================